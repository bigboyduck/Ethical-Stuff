                dragging = false
            end
        end)
        
        local function UpdateSlider(mouseX)
            if dragging then
                local sliderPos = SliderTrack.AbsolutePosition
                local sliderWidth = SliderTrack.AbsoluteSize.X
                local percent = math.clamp((mouseX - sliderPos.X) / sliderWidth, 0, 1)
                local value = min + (max - min) * percent
                if decimal then
                    value = math.round(value * 10) / 10
                else
                    value = math.round(value)
                end
                Config[configKey] = value
                SliderFill.Size = UDim2.new(percent, 0, 1, 0)
                SliderButton.Position = UDim2.new(percent, -9, 0.5, -9)
                ValueLabel.Text = string.format("%.1fs", value)
            end
        end
        
        SliderButton.MouseMoved:Connect(function()
            local mousePos = UserInputService:GetMouseLocation()
            UpdateSlider(mousePos.X)
        end)
        
        SliderTrack.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                local mousePos = UserInputService:GetMouseLocation()
                UpdateSlider(mousePos.X)
            end
        end)
