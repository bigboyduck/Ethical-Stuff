-- Optimized cache update
local function UpdateCache()
    local currentTime = tick()
    if currentTime - LastCacheUpdate < 5 and CachedTycoon then return end
    
    LastCacheUpdate = currentTime
    
    if not TycoonFound or not OwnedTycoon then return end
    
    CachedTycoon = Tycoons[OwnedTycoon]
    if not CachedTycoon then return end
    
    -- Cache purchase buttons
    CachedPurchaseButtons = {}
    CachedUpgradeButtons = {}
    CachedRebirthButtons = {}
    CachedBlenders = {}
    CachedDoors = {}
    CachedPackagers = {}
    
    -- Purchase buttons
    for _, container in pairs({"PurchaseButtons", "UpgradeButtons"}) do
        if CachedTycoon[container] then
            for _, v in pairs(CachedTycoon[container]:GetDescendants()) do
                if v:IsA("TextLabel") and v.Name == "Price" then
                    local button = container == "PurchaseButtons" and CachedPurchaseButtons or CachedUpgradeButtons
                    table.insert(button, v)
                end
            end
        end
    end
    
    -- Rebirth buttons
    if CachedTycoon.RebirthButtons then
        for _, v in pairs(CachedTycoon.RebirthButtons:GetDescendants()) do
            if v:IsA("TextLabel") and v.Name == "Price" then
                table.insert(CachedRebirthButtons, v)
            end
        end
    end
    
    -- Blenders
    if CachedTycoon.Purchases then
        for _, v in pairs(CachedTycoon.Purchases:GetDescendants()) do
            if v.Name == "ActivationLight" then
                table.insert(CachedBlenders, v)
            end
        end
    end
    
    -- Doors
    if CachedTycoon.ProcessingMachines then
        for _, v in pairs(CachedTycoon.ProcessingMachines:GetDescendants()) do
            if v:IsA("Model") and string.find(v.Name, "JarFactory") then
                for _, button in pairs(v:GetDescendants()) do
                    if button:IsA("ProximityPrompt") and button.Name == "OpenDoorPrompt" then
                        table.insert(CachedDoors, button)
                    end
                end
            elseif v:IsA("Model") and string.find(v.Name, "JarPackager") then
                for _, arrow in pairs(v:GetDescendants()) do
                    if arrow:IsA("BillboardGui") and arrow.Name == "Arrow" then
                        for _, prompt in pairs(arrow.Parent.Parent:GetDescendants()) do
                            if prompt:IsA("ProximityPrompt") and prompt.Name == "OpenDoorPrompt" then
                                table.insert(CachedPackagers, prompt)
                            end
                        end
                    end
                end
            end
        end
    end
    
    -- Crates
    CachedCrates = {}
    for _, v in pairs(Crates:GetDescendants()) do
        if v:IsA("TouchTransmitter") then
            table.insert(CachedCrates, v)
        end
    end
end

-- Optimized functions using cached data
local function PurchaseItems()
    local currentTime = tick()
    if currentTime - LastPurchaseTime < Config.PurchaseTimer then return end
    
    LastPurchaseTime = currentTime
    
    for _, button in ipairs(CachedPurchaseButtons) do
        if button.TextColor3 == Color3.fromRGB(114, 255, 112) then
            local buttonBase = button.Parent.Parent.Parent.ButtonBase
            if buttonBase then
                BuyRemote:FireServer(buttonBase.Parent.Name)
                return
            end
        end
    end
    
    for _, button in ipairs(CachedUpgradeButtons) do
        if button.TextColor3 == Color3.fromRGB(114, 255, 112) then
            local buttonBase = button.Parent.Parent.Parent.ButtonBase
            if buttonBase then
                BuyRemote:FireServer(buttonBase.Parent.Name)
                return
            end
        end
    end
end

local function Rebirth()
    local currentTime = tick()
    if currentTime - LastRebirthTime < 2 then return end
    
    for _, button in ipairs(CachedRebirthButtons) do
        if button.TextColor3 == Color3.fromRGB(114, 255, 112) then
            LastRebirthTime = currentTime
            RebirthRemote:FireServer()
            return
        end
    end
end

local function ActivateBlenders()
    local currentTime = tick()
    if currentTime - LastBlenderTime < 1 then return end
    
    for _, light in ipairs(CachedBlenders) do
        if light.Color == Color3.fromRGB(0, 255, 0) then
            local button = light.Parent.Button
            if button and button.Attachment and button.Attachment.ActivateBlender then
                LastBlenderTime = currentTime
                fireproximityprompt(button.Attachment.ActivateBlender)
                return
            end
        end
    end
end

local function OpenDoors()
    local currentTime = tick()
    if currentTime - LastDoorTime < 0.5 then return end
    
    for _, prompt in ipairs(CachedDoors) do
        if prompt.Enabled then
            LastDoorTime = currentTime
            fireproximityprompt(prompt)
            return
        end
    end
    
    for _, prompt in ipairs(CachedPackagers) do
        if prompt.Enabled then
            LastDoorTime = currentTime
            fireproximityprompt(prompt)
            return
        end
    end
end

local function FarmObbies()
    local currentTime = tick()
    if currentTime - LastObbyTime < 0.3 then return end
    
    for _, data in ipairs(ObbyData) do
        local obby, rebirthReq = data[1], data[2]
        local finish = obby:FindFirstChild("Finish")
        local decorations = obby:FindFirstChild("Decorations")
        
        if finish and finish:FindFirstChild("Button") and decorations then
            local obbySign = decorations:FindFirstChild("ObbySign")
            local border = obbySign and obbySign:FindFirstChild("Border")
            
            if border and not border.CanCollide and Rebirths.Value >= rebirthReq then
                LastObbyTime = currentTime
                local OldPos = HumanoidRootPart.CFrame
                firetouchinterest(finish.Button, HumanoidRootPart, 0)
                firetouchinterest(finish.Button, HumanoidRootPart, 1)
                task.wait(0.4)
                HumanoidRootPart.CFrame = OldPos
                return
            end
        end
    end
end

local function FarmCrates()
    local currentTime = tick()
    if currentTime - LastCrateTime < 0.1 then return end
    
    for _, transmitter in ipairs(CachedCrates) do
        if transmitter.Parent then
            LastCrateTime = currentTime
            firetouchinterest(transmitter.Parent, HumanoidRootPart, 0)
            firetouchinterest(transmitter.Parent, HumanoidRootPart, 1)
            return
        end
    end
end

-- Functions
local function OnCharacterAdded(NewCharacter)
    Character = NewCharacter
    HumanoidRootPart = NewCharacter:WaitForChild("HumanoidRootPart")
end

local function CheckTycoonOwnership()
    for _, v in pairs(Tycoons:GetDescendants()) do
        if v:IsA("ObjectValue") and v.Name == "Owner" and v.Value == LocalPlayer then
            OwnedTycoon, TycoonFound = v.Parent.Name, true
            UpdateCache()
            break
        end
    end
end

-- Create UI
CreateUI()

-- Connections
LocalPlayer.CharacterAdded:Connect(OnCharacterAdded)
if ClaimedPlot.Value then CheckTycoonOwnership() end
ClaimedPlot:GetPropertyChangedSignal("Value"):Connect(function()
    if ClaimedPlot.Value then
        task.wait(1)
        CheckTycoonOwnership()
    end
end)

-- Main Loop with cooldowns and caching
while IsRunning do
    task.wait(0.1) -- Reduce loop frequency
    
    if TycoonFound then
        -- Update cache periodically
        UpdateCache()
        
        if Config.AutoPurchase then PurchaseItems() end
        if Config.AutoRebirth then Rebirth() end
        if Config.AutoBlender then ActivateBlenders() end
        if Config.OpenDoors then OpenDoors() end
    end
    
    if Config.ObbyFarm and HumanoidRootPart then FarmObbies() end
    if Config.CrateFarm and HumanoidRootPart then FarmCrates() end
end
