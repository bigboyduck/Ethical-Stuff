task.spawn(function()
    while task.wait(2) do
        if _G.Running and _G.MyPlot then
            local utility = _G.MyPlot:FindFirstChild("Utility")
            if utility then
                local woodHolder = utility:FindFirstChild("WoodHolder")
                local woodChipper = utility:FindFirstChild("WoodChipper")
                if woodHolder and woodChipper then
                    rootPart.CFrame = woodHolder:GetPivot() + Vector3.new(0, 0, 3)
                    task.wait(0.3)
                    firePrompt(woodHolder)
                    task.wait(2)
                    rootPart.CFrame = woodChipper:GetPivot() + Vector3.new(0, 0, 3)
                    task.wait(0.3)
                    firePrompt(woodChipper)
                    task.wait(2)
                end
            end
        end
    end
end)
