_G.Running = false
_G.MyPlot = nil

local function findMyPlot()
    local plotsFolder = workspace:FindFirstChild("Map") and workspace.Map:FindFirstChild("Plots")
    if not plotsFolder then return nil end
    for _, plot in pairs(plotsFolder:GetChildren()) do
        local anchor = plot:FindFirstChild("NameTagAnchor")
        if anchor then
            local ownerTag = anchor:FindFirstChild("OwnerTag")
            if ownerTag then
                local nameObj = ownerTag:FindFirstChild("Name")
                if nameObj then
                    local ownerName = (nameObj:IsA("TextLabel") and nameObj.Text) or (nameObj:IsA("StringValue") and nameObj.Value)
                    if ownerName == player.Name then return plot end
                end
            end
        end
    end
    return nil
end

local function firePrompt(part)
    if not part then return end
    for _, descendant in pairs(part:GetDescendants()) do
        if descendant:IsA("ProximityPrompt") then
            fireproximityprompt(descendant)
            return true
        end
    end
    return false
end

